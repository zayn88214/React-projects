# This app uses Open-Meteo (https://open-meteo.com), which is free and does
# NOT require an API key for the forecast and geocoding endpoints used here.
#
# VITE_WEATHER_API_KEY is OPTIONAL. It exists so the same service layer can
# be pointed at a keyed provider (e.g. OpenWeatherMap) with minimal changes.
# Leave it blank to use Open-Meteo as-is.
VITE_WEATHER_API_KEY=
